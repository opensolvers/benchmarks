+template<MathOptimization opt = MathOptimization::Safe>
+static inline SimdFloat gmx_simdcall frexp(SimdFloat value, SimdFInt32* exponent)
+{
+    const vint32m1_t vi = __riscv_vreinterpret_v_f32m1_i32m1(value.simdInternal_);
+    // IEEE754 binary32: extract biased exponent (bits 30:23), rebias to frexp
+    // convention (mantissa in [0.5,1)) by subtracting 126; keep sign+mantissa
+    // and force exponent field to 0x3F (0.5) via the mantissa mask + 0.5 bits.
+    vint32m1_t iExponent = __riscv_vand_vx_i32m1(vi, 0x7F800000, gmxRvvVlF);
+    iExponent            = __riscv_vreinterpret_v_u32m1_i32m1(__riscv_vsrl_vx_u32m1(
+            __riscv_vreinterpret_v_i32m1_u32m1(iExponent), 23u, gmxRvvVlF));
+    iExponent            = __riscv_vsub_vx_i32m1(iExponent, 126, gmxRvvVlF);
+
+    const vint32m1_t half = __riscv_vreinterpret_v_f32m1_i32m1(__riscv_vfmv_v_f_f32m1(0.5f, gmxRvvVlF));
+    vfloat32m1_t     result = __riscv_vreinterpret_v_i32m1_f32m1(
+            __riscv_vor_vv_i32m1(__riscv_vand_vx_i32m1(vi, 0x807FFFFF, gmxRvvVlF), half, gmxRvvVlF));
+
+    if (opt == MathOptimization::Safe)
+    {
+        vbool32_t valueIsZero = __riscv_vmfeq_vf_f32m1_b32(value.simdInternal_, 0.0f, gmxRvvVlF);
+        iExponent = __riscv_vmerge_vxm_i32m1(iExponent, 0, valueIsZero, gmxRvvVlF);
+        result    = __riscv_vmerge_vvm_f32m1(result, value.simdInternal_, valueIsZero, gmxRvvVlF);
+    }
+
+    exponent->simdInternal_ = iExponent;
+    return { result };
+}
+
+template<MathOptimization opt = MathOptimization::Safe>
+static inline SimdFloat gmx_simdcall ldexp(SimdFloat value, SimdFInt32 exponent)
+{
+    vint32m1_t iExponent = __riscv_vadd_vx_i32m1(exponent.simdInternal_, 127, gmxRvvVlF);
+
+    if (opt == MathOptimization::Safe)
+    {
+        iExponent = __riscv_vmax_vx_i32m1(iExponent, 0, gmxRvvVlF);
+    }
+
+    iExponent = __riscv_vsll_vx_i32m1(iExponent, 23u, gmxRvvVlF);
+
+    return { __riscv_vfmul_vv_f32m1(
+            value.simdInternal_, __riscv_vreinterpret_v_i32m1_f32m1(iExponent), gmxRvvVlF) };
+}
