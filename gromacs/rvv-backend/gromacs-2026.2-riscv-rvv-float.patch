+// (256 on the X60). At VLEN=256: FLOAT_WIDTH=8, DOUBLE_WIDTH=4.
+#define GMX_SIMD_FLOAT_WIDTH (GMX_SIMD_RISCV_RVV_LENGTH_VALUE / 32)
+#define GMX_SIMD_DOUBLE_WIDTH (GMX_SIMD_RISCV_RVV_LENGTH_VALUE / 64)
+#define GMX_SIMD_FINT32_WIDTH GMX_SIMD_FLOAT_WIDTH
+#define GMX_SIMD_DINT32_WIDTH GMX_SIMD_DOUBLE_WIDTH
+#define GMX_SIMD4_WIDTH 4
+#define GMX_SIMD_RSQRT_BITS 7 // vfrsqrt7 gives 7 bits; refinement in simd_math.h
