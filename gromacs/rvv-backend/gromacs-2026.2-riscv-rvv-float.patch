+/*
+ * RISC-V RVV 1.0 float util support (gather/scatter/transpose). Translated from
+ * impl_arm_sve_util_float.h.
+ *
+ * HSIMD util (GMX_SIMD_HAVE_HSIMD_UTIL_FLOAT==0) and the gather-loadU-by-simdint
+ * variants (flag==0) are out of scope, so their SVE functions are not ported.
+ *
+ * SVE->RVV notes: RVV indexed load/store (vluxei32/vsuxei32) take BYTE offsets
+ * relative to the typed base pointer, so element offsets are scaled by
+ * align*sizeof(float) and stepped by sizeof(float) between transposed columns.
+ * The += / -= scatters (transposeScatterIncrU/DecrU) must use a scalar
+ * read-modify-write loop, since a vector scatter is not collision-correct when
+ * two lanes target the same address.
+ */
+
+#ifndef GMX_SIMD_IMPL_RISCV_RVV_UTIL_FLOAT_H
+#define GMX_SIMD_IMPL_RISCV_RVV_UTIL_FLOAT_H
+
+#include "config.h"
+
+#include <riscv_vector.h>
+
+#include <cassert>
+#include <cstddef>
+#include <cstdint>
+
+#include "gromacs/simd/impl_riscv_rvv/impl_riscv_rvv_simd_float.h"
+#include "gromacs/utility/basedefinitions.h"
+
+namespace gmx
+{
+
+// Element offsets -> byte offsets for the indexed load/store intrinsics, scaled
+// by the compile-time struct stride `align` and sizeof(float).
+template<int align>
+static inline vuint32m1_t gmxRvvScaledByteOffsets(SimdFInt32 offset)
+{
+    static_assert(align > 0, "align must be positive");
+    vuint32m1_t uoffset = __riscv_vreinterpret_v_i32m1_u32m1(offset.simdInternal_);
+    return __riscv_vmul_vx_u32m1(uoffset, static_cast<uint32_t>(align * 4), gmxRvvVlF);
+}
+
+template<int align>
+static inline vuint32m1_t gmxRvvLoadScaledByteOffsets(const std::int32_t offset[])
+{
+    SimdFInt32 simdOffset{ __riscv_vle32_v_i32m1(offset, gmxRvvVlF) };
+    return gmxRvvScaledByteOffsets<align>(simdOffset);
+}
+
+// Horizontal sum of the active lanes; scalar accumulator lives in lane 0.
+static inline float gmxRvvReduceF32(vfloat32m1_t v, size_t vl)
+{
+    vfloat32m1_t zero = __riscv_vfmv_v_f_f32m1(0.0f, 1);
+    vfloat32m1_t sum  = __riscv_vfredusum_vs_f32m1_f32m1(v, zero, vl);
+    return __riscv_vfmv_f_s_f32m1_f32(sum);
+}
+
+template<int align>
+static inline void gmx_simdcall
+gatherLoadBySimdIntTranspose(const float* base, SimdFInt32 offset, SimdFloat* v0, SimdFloat* v1, SimdFloat* v2, SimdFloat* v3)
+{
+    assert(std::size_t(base) % (std::min(GMX_SIMD_FLOAT_WIDTH, 4) * sizeof(float)) == 0);
+    assert(align % std::min(GMX_SIMD_FLOAT_WIDTH, 4) == 0);
+
+    vuint32m1_t byteOffsets = gmxRvvScaledByteOffsets<align>(offset);
+
+    *v0        = { __riscv_vluxei32_v_f32m1(base, byteOffsets, gmxRvvVlF) };
+    byteOffsets = __riscv_vadd_vx_u32m1(byteOffsets, uint32_t{ 4 }, gmxRvvVlF);
+    *v1        = { __riscv_vluxei32_v_f32m1(base, byteOffsets, gmxRvvVlF) };
+    byteOffsets = __riscv_vadd_vx_u32m1(byteOffsets, uint32_t{ 4 }, gmxRvvVlF);
+    *v2        = { __riscv_vluxei32_v_f32m1(base, byteOffsets, gmxRvvVlF) };
+    byteOffsets = __riscv_vadd_vx_u32m1(byteOffsets, uint32_t{ 4 }, gmxRvvVlF);
+    *v3        = { __riscv_vluxei32_v_f32m1(base, byteOffsets, gmxRvvVlF) };
+}
+
+template<int align>
+static inline void gmx_simdcall
+gatherLoadBySimdIntTranspose(const float* base, SimdFInt32 offset, SimdFloat* v0, SimdFloat* v1)
+{
+    assert(std::size_t(base) % (std::min(GMX_SIMD_FLOAT_WIDTH, 2) * sizeof(float)) == 0);
+    assert(align % std::min(GMX_SIMD_FLOAT_WIDTH, 2) == 0);
+
+    vuint32m1_t byteOffsets = gmxRvvScaledByteOffsets<align>(offset);
+
+    *v0        = { __riscv_vluxei32_v_f32m1(base, byteOffsets, gmxRvvVlF) };
+    byteOffsets = __riscv_vadd_vx_u32m1(byteOffsets, uint32_t{ 4 }, gmxRvvVlF);
+    *v1        = { __riscv_vluxei32_v_f32m1(base, byteOffsets, gmxRvvVlF) };
+}
+
+template<int align>
+static inline void gmx_simdcall gatherLoadTranspose(const float*       base,
+                                                    const std::int32_t offset[],
+                                                    SimdFloat*         v0,
+                                                    SimdFloat*         v1,
+                                                    SimdFloat*         v2,
+                                                    SimdFloat*         v3)
+{
+    assert(std::size_t(offset) % (GMX_SIMD_FINT32_WIDTH * sizeof(std::int32_t)) == 0);
+
+    SimdFInt32 simdOffset{ __riscv_vle32_v_i32m1(offset, gmxRvvVlF) };
+    gatherLoadBySimdIntTranspose<align>(base, simdOffset, v0, v1, v2, v3);
+}
+
+template<int align>
+static inline void gmx_simdcall
+gatherLoadTranspose(const float* base, const std::int32_t offset[], SimdFloat* v0, SimdFloat* v1)
+{
+    assert(std::size_t(offset) % (GMX_SIMD_FINT32_WIDTH * sizeof(std::int32_t)) == 0);
+
+    SimdFInt32 simdOffset{ __riscv_vle32_v_i32m1(offset, gmxRvvVlF) };
+    gatherLoadBySimdIntTranspose<align>(base, simdOffset, v0, v1);
+}
+
+// c_simdBestPairAlignmentFloat is defined in impl_riscv_rvv_simd4_float.h (hoisted
+// there to break an include cycle).
+
+template<int align>
+static inline void gmx_simdcall gatherLoadUTranspose(const float*       base,
+                                                     const std::int32_t offset[],
+                                                     SimdFloat*         v0,
+                                                     SimdFloat*         v1,
+                                                     SimdFloat*         v2)
+{
+    assert(std::size_t(offset) % (GMX_SIMD_FINT32_WIDTH * sizeof(std::int32_t)) == 0);
+
+    vuint32m1_t byteOffsets = gmxRvvLoadScaledByteOffsets<align>(offset);
+
+    *v0        = { __riscv_vluxei32_v_f32m1(base, byteOffsets, gmxRvvVlF) };
+    byteOffsets = __riscv_vadd_vx_u32m1(byteOffsets, uint32_t{ 4 }, gmxRvvVlF);
+    *v1        = { __riscv_vluxei32_v_f32m1(base, byteOffsets, gmxRvvVlF) };
+    byteOffsets = __riscv_vadd_vx_u32m1(byteOffsets, uint32_t{ 4 }, gmxRvvVlF);
+    *v2        = { __riscv_vluxei32_v_f32m1(base, byteOffsets, gmxRvvVlF) };
+}
+
+template<int align>
+static inline void gmx_simdcall
+transposeScatterStoreU(float* base, const std::int32_t offset[], SimdFloat v0, SimdFloat v1, SimdFloat v2)
+{
+    assert(std::size_t(offset) % (GMX_SIMD_FINT32_WIDTH * sizeof(std::int32_t)) == 0);
+
+    vuint32m1_t byteOffsets = gmxRvvLoadScaledByteOffsets<align>(offset);
+
+    __riscv_vsuxei32_v_f32m1(base, byteOffsets, v0.simdInternal_, gmxRvvVlF);
+    byteOffsets = __riscv_vadd_vx_u32m1(byteOffsets, uint32_t{ 4 }, gmxRvvVlF);
+    __riscv_vsuxei32_v_f32m1(base, byteOffsets, v1.simdInternal_, gmxRvvVlF);
+    byteOffsets = __riscv_vadd_vx_u32m1(byteOffsets, uint32_t{ 4 }, gmxRvvVlF);
+    __riscv_vsuxei32_v_f32m1(base, byteOffsets, v2.simdInternal_, gmxRvvVlF);
+}
+
+// += scatter: scalar read-modify-write, since duplicate offsets would make a
+// vector scatter lose updates.
+template<int align>
+static inline void gmx_simdcall
+transposeScatterIncrU(float* base, const std::int32_t offset[], SimdFloat v0, SimdFloat v1, SimdFloat v2)
+{
+    assert(std::size_t(offset) % (GMX_SIMD_FINT32_WIDTH * sizeof(std::int32_t)) == 0);
+
+    alignas(GMX_SIMD_ALIGNMENT) float s0[GMX_SIMD_FLOAT_WIDTH];
+    alignas(GMX_SIMD_ALIGNMENT) float s1[GMX_SIMD_FLOAT_WIDTH];
+    alignas(GMX_SIMD_ALIGNMENT) float s2[GMX_SIMD_FLOAT_WIDTH];
+
+    __riscv_vse32_v_f32m1(s0, v0.simdInternal_, gmxRvvVlF);
+    __riscv_vse32_v_f32m1(s1, v1.simdInternal_, gmxRvvVlF);
+    __riscv_vse32_v_f32m1(s2, v2.simdInternal_, gmxRvvVlF);
+
+    for (std::size_t i = 0; i < GMX_SIMD_FLOAT_WIDTH; ++i)
+    {
+        const std::int32_t j = align * offset[i];
+        base[j + 0] += s0[i];
+        base[j + 1] += s1[i];
+        base[j + 2] += s2[i];
+    }
+}
+
+// -= scatter: scalar read-modify-write (see transposeScatterIncrU).
+template<int align>
+static inline void gmx_simdcall
+transposeScatterDecrU(float* base, const std::int32_t offset[], SimdFloat v0, SimdFloat v1, SimdFloat v2)
+{
+    assert(std::size_t(offset) % (GMX_SIMD_FINT32_WIDTH * sizeof(std::int32_t)) == 0);
+
+    alignas(GMX_SIMD_ALIGNMENT) float s0[GMX_SIMD_FLOAT_WIDTH];
+    alignas(GMX_SIMD_ALIGNMENT) float s1[GMX_SIMD_FLOAT_WIDTH];
+    alignas(GMX_SIMD_ALIGNMENT) float s2[GMX_SIMD_FLOAT_WIDTH];
+
+    __riscv_vse32_v_f32m1(s0, v0.simdInternal_, gmxRvvVlF);
+    __riscv_vse32_v_f32m1(s1, v1.simdInternal_, gmxRvvVlF);
+    __riscv_vse32_v_f32m1(s2, v2.simdInternal_, gmxRvvVlF);
+
+    for (std::size_t i = 0; i < GMX_SIMD_FLOAT_WIDTH; ++i)
+    {
+        const std::int32_t j = align * offset[i];
+        base[j + 0] -= s0[i];
+        base[j + 1] -= s1[i];
+        base[j + 2] -= s2[i];
+    }
+}
+
+static inline void gmx_simdcall expandScalarsToTriplets(SimdFloat  scalar,
+                                                        SimdFloat* triplets0,
+                                                        SimdFloat* triplets1,
+                                                        SimdFloat* triplets2)
+{
+    assert(GMX_SIMD_FLOAT_WIDTH <= 16);
+    // Lane i of triplets{0,1,2} pulls scalar lane i/3 across the three vectors,
+    // so gather index = floor(globalTripletIndex / 3).
+    static const uint32_t ind[3 * GMX_SIMD_FLOAT_WIDTH] = {
+        0, 0, 0, 1, 1, 1, 2, 2, 2, 3, 3, 3, 4, 4, 4, 5,
+        5, 5, 6, 6, 6, 7, 7, 7
+    };
+
+    vuint32m1_t i0 = __riscv_vle32_v_u32m1(ind + 0, gmxRvvVlF);
+    vuint32m1_t i1 = __riscv_vle32_v_u32m1(ind + GMX_SIMD_FLOAT_WIDTH, gmxRvvVlF);
+    vuint32m1_t i2 = __riscv_vle32_v_u32m1(ind + 2 * GMX_SIMD_FLOAT_WIDTH, gmxRvvVlF);
+
+    triplets0->simdInternal_ = __riscv_vrgather_vv_f32m1(scalar.simdInternal_, i0, gmxRvvVlF);
+    triplets1->simdInternal_ = __riscv_vrgather_vv_f32m1(scalar.simdInternal_, i1, gmxRvvVlF);
+    triplets2->simdInternal_ = __riscv_vrgather_vv_f32m1(scalar.simdInternal_, i2, gmxRvvVlF);
+}
+
+static inline float gmx_simdcall reduceIncr4ReturnSum(float* m, SimdFloat v0, SimdFloat v1, SimdFloat v2, SimdFloat v3)
+{
+    assert(std::size_t(m) % (std::min(GMX_SIMD_FLOAT_WIDTH, 4) * sizeof(float)) == 0);
+
+    alignas(GMX_SIMD_ALIGNMENT) float s[GMX_SIMD4_WIDTH] = {
+        gmxRvvReduceF32(v0.simdInternal_, gmxRvvVlF),
+        gmxRvvReduceF32(v1.simdInternal_, gmxRvvVlF),
+        gmxRvvReduceF32(v2.simdInternal_, gmxRvvVlF),
+        gmxRvvReduceF32(v3.simdInternal_, gmxRvvVlF)
+    };
+
+    const size_t vl4  = GMX_SIMD4_WIDTH;
+    vfloat32m1_t mVec = __riscv_vle32_v_f32m1(m, vl4);
+    vfloat32m1_t sVec = __riscv_vle32_v_f32m1(s, vl4);
+    __riscv_vse32_v_f32m1(m, __riscv_vfadd_vv_f32m1(mVec, sVec, vl4), vl4);
+
+    return gmxRvvReduceF32(sVec, vl4);
+}
+
+} // namespace gmx
+
+#endif // GMX_SIMD_IMPL_RISCV_RVV_UTIL_FLOAT_H
