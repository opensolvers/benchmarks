+/*
+ * RISC-V RVV 1.0 SIMD4 (fixed 4-lane) float support. Translated from
+ * impl_arm_sve_simd4_float.h.
+ *
+ * SIMD4 is a hardware-independent fixed width of 4 float32 lanes. On the X60
+ * (VLEN=256) the full vfloat32m1_t holds 8 lanes, so every SIMD4 op runs with
+ * vl=4: lanes 0..3 are the SIMD4 value and lanes 4..7 are garbage. This is safe
+ * as long as EVERY consumer of a Simd4Float uses vl=4 (or narrower), which this
+ * header enforces. Masks follow the same sized-vuint32m1_t storage strategy as
+ * the main float header (see impl_riscv_rvv_simd_float.h): vbool32_t is sizeless
+ * and cannot be a class member, so Simd4FBool stores 0x0/0xFFFFFFFF lane values
+ * and converts to an ephemeral vbool32_t only at intrinsic boundaries.
+ */
+
+#ifndef GMX_SIMD_IMPL_RISCV_RVV_SIMD4_FLOAT_H
+#define GMX_SIMD_IMPL_RISCV_RVV_SIMD4_FLOAT_H
+
+#include "config.h"
+
+#include <riscv_vector.h>
+
+#include <cassert>
+#include <cstddef>
+#include <cstdint>
+
+#include "gromacs/math/utilities.h"
+
+namespace gmx
+{
+
+// SIMD4 operates on exactly 4 float32 lanes regardless of hardware VLEN.
+static const size_t gmxRvvVl4 = 4;
+
+// Belongs in util_float (SVE reference); hoisted here so simd.h can define
+// c_simdBestPairAlignment before the util phase lands.
+static const int c_simdBestPairAlignmentFloat = 2;
+
+class Simd4Float
+{
+private:
+    typedef vfloat32m1_t simdInternalType_ __attribute__((riscv_rvv_vector_bits(GMX_SIMD_RISCV_RVV_LENGTH_VALUE)));
+
+public:
+    Simd4Float() {}
+
+    Simd4Float(float f) { this->simdInternal_ = __riscv_vfmv_v_f_f32m1(f, gmxRvvVl4); }
+
+    Simd4Float(vfloat32m1_t simd) : simdInternal_(simd) {}
+
+    simdInternalType_ simdInternal_;
+};
+
+// Same sized-mask storage as the main float header. Lanes are 0x0 (false) or
+// 0xFFFFFFFF (true); a vbool32_t is materialized ephemerally when a mask is
+// consumed. NOTE: never vreinterpret between vbool32_t and vuint32m1_t.
+class Simd4FBool
+{
+private:
+    typedef vuint32m1_t simdBoolStore_ __attribute__((riscv_rvv_vector_bits(GMX_SIMD_RISCV_RVV_LENGTH_VALUE)));
+
+public:
+    Simd4FBool() {}
+
+    Simd4FBool(bool b)
+    {
+        this->simdInternal_ = __riscv_vmv_v_x_u32m1(b ? 0xFFFFFFFFu : 0u, gmxRvvVl4);
+    }
+
+    Simd4FBool(vbool32_t m)
+    {
+        vuint32m1_t zero    = __riscv_vmv_v_x_u32m1(0u, gmxRvvVl4);
+        this->simdInternal_ = __riscv_vmerge_vxm_u32m1(zero, 0xFFFFFFFFu, m, gmxRvvVl4);
+    }
+
+    Simd4FBool(simdBoolStore_ store) : simdInternal_(store) {}
+
+    simdBoolStore_ simdInternal_;
+};
+
+// Simd4FBool sized-store -> ephemeral vbool32_t (nonzero lane => true).
+static inline vbool32_t gmx_simdcall simd4BoolToMask(Simd4FBool a)
+{
+    return __riscv_vmsne_vx_u32m1_b32(a.simdInternal_, 0u, gmxRvvVl4);
+}
+
+static inline Simd4Float gmx_simdcall load4(const float* m)
+{
+    assert(std::size_t(m) % (GMX_SIMD4_WIDTH * sizeof(float)) == 0);
+    return { __riscv_vle32_v_f32m1(m, gmxRvvVl4) };
+}
+
+static inline void gmx_simdcall store4(float* m, Simd4Float a)
+{
+    assert(std::size_t(m) % (GMX_SIMD4_WIDTH * sizeof(float)) == 0);
+    __riscv_vse32_v_f32m1(m, a.simdInternal_, gmxRvvVl4);
+}
+
+static inline Simd4Float gmx_simdcall load4U(const float* m)
+{
+    return { __riscv_vle32_v_f32m1(m, gmxRvvVl4) };
+}
+
+static inline void gmx_simdcall store4U(float* m, Simd4Float a)
+{
+    __riscv_vse32_v_f32m1(m, a.simdInternal_, gmxRvvVl4);
+}
+
+static inline Simd4Float gmx_simdcall simd4SetZeroF()
+{
+    return { __riscv_vfmv_v_f_f32m1(0.0f, gmxRvvVl4) };
+}
+
+// Bitwise logic on floats goes through the integer reinterpretation intrinsics
+// (bit-preserving; distinct from the forbidden vbool<->vuint reinterpret).
+static inline Simd4Float gmx_simdcall operator&(Simd4Float a, Simd4Float b)
+{
+    vuint32m1_t ia = __riscv_vreinterpret_v_f32m1_u32m1(a.simdInternal_);
+    vuint32m1_t ib = __riscv_vreinterpret_v_f32m1_u32m1(b.simdInternal_);
+    return { __riscv_vreinterpret_v_u32m1_f32m1(__riscv_vand_vv_u32m1(ia, ib, gmxRvvVl4)) };
+}
+
+static inline Simd4Float gmx_simdcall andNot(Simd4Float a, Simd4Float b)
+{
+    // andNot(a, b) == (~a) & b
+    vuint32m1_t ia  = __riscv_vreinterpret_v_f32m1_u32m1(a.simdInternal_);
+    vuint32m1_t ib  = __riscv_vreinterpret_v_f32m1_u32m1(b.simdInternal_);
+    vuint32m1_t nia = __riscv_vnot_v_u32m1(ia, gmxRvvVl4);
+    return { __riscv_vreinterpret_v_u32m1_f32m1(__riscv_vand_vv_u32m1(nia, ib, gmxRvvVl4)) };
+}
+
+static inline Simd4Float gmx_simdcall operator|(Simd4Float a, Simd4Float b)
+{
+    vuint32m1_t ia = __riscv_vreinterpret_v_f32m1_u32m1(a.simdInternal_);
+    vuint32m1_t ib = __riscv_vreinterpret_v_f32m1_u32m1(b.simdInternal_);
+    return { __riscv_vreinterpret_v_u32m1_f32m1(__riscv_vor_vv_u32m1(ia, ib, gmxRvvVl4)) };
+}
+
+static inline Simd4Float gmx_simdcall operator^(Simd4Float a, Simd4Float b)
+{
+    vuint32m1_t ia = __riscv_vreinterpret_v_f32m1_u32m1(a.simdInternal_);
+    vuint32m1_t ib = __riscv_vreinterpret_v_f32m1_u32m1(b.simdInternal_);
+    return { __riscv_vreinterpret_v_u32m1_f32m1(__riscv_vxor_vv_u32m1(ia, ib, gmxRvvVl4)) };
+}
+
+static inline Simd4Float gmx_simdcall operator+(Simd4Float a, Simd4Float b)
+{
+    return { __riscv_vfadd_vv_f32m1(a.simdInternal_, b.simdInternal_, gmxRvvVl4) };
+}
+
+static inline Simd4Float gmx_simdcall operator-(Simd4Float a, Simd4Float b)
+{
+    return { __riscv_vfsub_vv_f32m1(a.simdInternal_, b.simdInternal_, gmxRvvVl4) };
+}
+
+static inline Simd4Float gmx_simdcall operator-(Simd4Float a)
+{
+    return { __riscv_vfneg_v_f32m1(a.simdInternal_, gmxRvvVl4) };
+}
+
+static inline Simd4Float gmx_simdcall operator*(Simd4Float a, Simd4Float b)
+{
+    return { __riscv_vfmul_vv_f32m1(a.simdInternal_, b.simdInternal_, gmxRvvVl4) };
+}
+
+// GROMACS fma(a,b,c) = a*b + c. RVV vfmacc(acc,x,y) = acc + x*y => acc=c, x=a, y=b.
+static inline Simd4Float gmx_simdcall fma(Simd4Float a, Simd4Float b, Simd4Float c)
+{
+    return { __riscv_vfmacc_vv_f32m1(c.simdInternal_, a.simdInternal_, b.simdInternal_, gmxRvvVl4) };
+}
+
+// fms(a,b,c) = a*b - c. vfmsac(acc,x,y) = x*y - acc => acc=c, x=a, y=b.
+static inline Simd4Float gmx_simdcall fms(Simd4Float a, Simd4Float b, Simd4Float c)
+{
+    return { __riscv_vfmsac_vv_f32m1(c.simdInternal_, a.simdInternal_, b.simdInternal_, gmxRvvVl4) };
+}
+
+// fnma(a,b,c) = -a*b + c = c - a*b. vfnmsac(acc,x,y) = acc - x*y => acc=c, x=a, y=b.
+static inline Simd4Float gmx_simdcall fnma(Simd4Float a, Simd4Float b, Simd4Float c)
+{
+    return { __riscv_vfnmsac_vv_f32m1(c.simdInternal_, a.simdInternal_, b.simdInternal_, gmxRvvVl4) };
+}
+
+// fnms(a,b,c) = -a*b - c. vfnmacc(acc,x,y) = -(acc + x*y) => acc=c, x=a, y=b.
+static inline Simd4Float gmx_simdcall fnms(Simd4Float a, Simd4Float b, Simd4Float c)
+{
+    return { __riscv_vfnmacc_vv_f32m1(c.simdInternal_, a.simdInternal_, b.simdInternal_, gmxRvvVl4) };
+}
+
+static inline Simd4Float gmx_simdcall rsqrt(Simd4Float x)
+{
+    // 7-bit seed only (matches main float header; refined by Newton-Raphson in the caller).
+    return { __riscv_vfrsqrt7_v_f32m1(x.simdInternal_, gmxRvvVl4) };
+}
+
+static inline Simd4Float gmx_simdcall abs(Simd4Float x)
+{
+    return { __riscv_vfabs_v_f32m1(x.simdInternal_, gmxRvvVl4) };
+}
+
+static inline Simd4Float gmx_simdcall max(Simd4Float a, Simd4Float b)
+{
+    return { __riscv_vfmax_vv_f32m1(a.simdInternal_, b.simdInternal_, gmxRvvVl4) };
+}
+
+static inline Simd4Float gmx_simdcall min(Simd4Float a, Simd4Float b)
+{
+    return { __riscv_vfmin_vv_f32m1(a.simdInternal_, b.simdInternal_, gmxRvvVl4) };
+}
+
+static inline Simd4Float gmx_simdcall round(Simd4Float x)
+{
+    // Round to nearest even: convert to int (RNE is the default rounding mode) and back.
+    vint32m1_t i = __riscv_vfcvt_x_f_v_i32m1(x.simdInternal_, gmxRvvVl4);
+    return { __riscv_vfcvt_f_x_v_f32m1(i, gmxRvvVl4) };
+}
+
+static inline Simd4Float gmx_simdcall trunc(Simd4Float x)
+{
+    // Round toward zero: use the rtz convert variant.
+    vint32m1_t i = __riscv_vfcvt_rtz_x_f_v_i32m1(x.simdInternal_, gmxRvvVl4);
+    return { __riscv_vfcvt_f_x_v_f32m1(i, gmxRvvVl4) };
+}
+
+static inline float gmx_simdcall reduce(Simd4Float a)
+{
+    vfloat32m1_t zero = __riscv_vfmv_v_f_f32m1(0.0f, gmxRvvVl4);
+    vfloat32m1_t r    = __riscv_vfredusum_vs_f32m1_f32m1(a.simdInternal_, zero, gmxRvvVl4);
+    return __riscv_vfmv_f_s_f32m1_f32(r);
+}
+
+static inline Simd4FBool gmx_simdcall operator==(Simd4Float a, Simd4Float b)
+{
+    return { __riscv_vmfeq_vv_f32m1_b32(a.simdInternal_, b.simdInternal_, gmxRvvVl4) };
+}
+
+static inline Simd4FBool gmx_simdcall operator!=(Simd4Float a, Simd4Float b)
+{
+    return { __riscv_vmfne_vv_f32m1_b32(a.simdInternal_, b.simdInternal_, gmxRvvVl4) };
+}
+
+static inline Simd4FBool gmx_simdcall operator<(Simd4Float a, Simd4Float b)
+{
+    return { __riscv_vmflt_vv_f32m1_b32(a.simdInternal_, b.simdInternal_, gmxRvvVl4) };
+}
+
+static inline Simd4FBool gmx_simdcall operator<=(Simd4Float a, Simd4Float b)
+{
+    return { __riscv_vmfle_vv_f32m1_b32(a.simdInternal_, b.simdInternal_, gmxRvvVl4) };
+}
+
+static inline Simd4FBool gmx_simdcall operator&&(Simd4FBool a, Simd4FBool b)
+{
+    return { __riscv_vand_vv_u32m1(a.simdInternal_, b.simdInternal_, gmxRvvVl4) };
+}
+
+static inline Simd4FBool gmx_simdcall operator||(Simd4FBool a, Simd4FBool b)
+{
+    return { __riscv_vor_vv_u32m1(a.simdInternal_, b.simdInternal_, gmxRvvVl4) };
+}
+
+static inline bool gmx_simdcall anyTrue(Simd4FBool a)
+{
+    vbool32_t mb = simd4BoolToMask(a);
+    return __riscv_vcpop_m_b32(mb, gmxRvvVl4) != 0;
+}
+
+static inline Simd4Float gmx_simdcall selectByMask(Simd4Float a, Simd4FBool m)
+{
+    vbool32_t    mb   = simd4BoolToMask(m);
+    vfloat32m1_t zero = __riscv_vfmv_v_f_f32m1(0.0f, gmxRvvVl4);
+    // mask true => keep a, mask false => 0.
+    return { __riscv_vmerge_vvm_f32m1(zero, a.simdInternal_, mb, gmxRvvVl4) };
+}
+
+static inline Simd4Float gmx_simdcall selectByNotMask(Simd4Float a, Simd4FBool m)
+{
+    vbool32_t    mb   = simd4BoolToMask(m);
+    vfloat32m1_t zero = __riscv_vfmv_v_f_f32m1(0.0f, gmxRvvVl4);
+    // mask true => 0, mask false => keep a.
+    return { __riscv_vmerge_vvm_f32m1(a.simdInternal_, zero, mb, gmxRvvVl4) };
+}
+
+static inline Simd4Float gmx_simdcall blend(Simd4Float a, Simd4Float b, Simd4FBool sel)
+{
+    vbool32_t mb = simd4BoolToMask(sel);
+    // vmerge_vvm(a, b, mask) => mask ? b : a.
+    return { __riscv_vmerge_vvm_f32m1(a.simdInternal_, b.simdInternal_, mb, gmxRvvVl4) };
+}
+
+static inline float gmx_simdcall dotProduct(Simd4Float a, Simd4Float b)
+{
+    // 3-component dot product: multiply and reduce only lanes 0..2 (vl=3), so
+    // lane 3 never participates (matches the NEON reference which zeroes it).
+    const size_t vl3  = 3;
+    vfloat32m1_t prod = __riscv_vfmul_vv_f32m1(a.simdInternal_, b.simdInternal_, vl3);
+    vfloat32m1_t zero = __riscv_vfmv_v_f_f32m1(0.0f, vl3);
+    vfloat32m1_t r    = __riscv_vfredusum_vs_f32m1_f32m1(prod, zero, vl3);
+    return __riscv_vfmv_f_s_f32m1_f32(r);
+}
+
+static inline void gmx_simdcall transpose(Simd4Float* v0, Simd4Float* v1, Simd4Float* v2, Simd4Float* v3)
+{
+    // RVV has no NEON-style vtrn/vuzp. Store the four rows into row-major
+    // scratch, then reload each column with a strided load (stride 4 floats).
+    alignas(GMX_SIMD_ALIGNMENT) float tmp[16];
+
+    __riscv_vse32_v_f32m1(tmp + 0, v0->simdInternal_, gmxRvvVl4);
+    __riscv_vse32_v_f32m1(tmp + 4, v1->simdInternal_, gmxRvvVl4);
+    __riscv_vse32_v_f32m1(tmp + 8, v2->simdInternal_, gmxRvvVl4);
+    __riscv_vse32_v_f32m1(tmp + 12, v3->simdInternal_, gmxRvvVl4);
+
+    const ptrdiff_t stride = 4 * static_cast<ptrdiff_t>(sizeof(float));
+
+    v0->simdInternal_ = __riscv_vlse32_v_f32m1(tmp + 0, stride, gmxRvvVl4);
+    v1->simdInternal_ = __riscv_vlse32_v_f32m1(tmp + 1, stride, gmxRvvVl4);
+    v2->simdInternal_ = __riscv_vlse32_v_f32m1(tmp + 2, stride, gmxRvvVl4);
+    v3->simdInternal_ = __riscv_vlse32_v_f32m1(tmp + 3, stride, gmxRvvVl4);
+}
+
+} // namespace gmx
+
+#endif // GMX_SIMD_IMPL_RISCV_RVV_SIMD4_FLOAT_H
