diff --git a/cmake/gmxSimdFlags.cmake b/cmake/gmxSimdFlags.cmake
index a264132..d89673f 100644
--- a/cmake/gmxSimdFlags.cmake
+++ b/cmake/gmxSimdFlags.cmake
@@ -309,6 +309,29 @@ function(gmx_find_simd_arm_sve_flags C_FLAGS_RESULT CXX_FLAGS_RESULT C_FLAGS_VAR
     set(${CXX_FLAGS_RESULT} ${SIMD_ARM_SVE_CXX_FLAGS_RESULT} CACHE INTERNAL "Result of test for Arm SVE C++ flags" FORCE)
 endfunction()
 
+function(gmx_find_simd_riscv_rvv_flags C_FLAGS_RESULT CXX_FLAGS_RESULT C_FLAGS_VARIABLE CXX_FLAGS_VARIABLE)
+
+    gmx_find_flags(SIMD_RISCV_RVV_C_FLAGS_RESULT SIMD_RISCV_RVV_CXX_FLAGS_RESULT
+        "#include <riscv_vector.h>
+         /* Fixed-length RVV: requires -mrvv-vector-bits=zvl and a zvlNNNb target.
+            The __riscv_ intrinsic prefix is mandatory on GCC 14.x. */
+         typedef vfloat32m1_t float32_vec_t __attribute__((riscv_rvv_vector_bits(${GMX_SIMD_RISCV_RVV_LENGTH_VALUE})));
+         int main(){float32_vec_t x = __riscv_vfmv_v_f_f32m1(0.5f, ${GMX_SIMD_RISCV_RVV_LENGTH_VALUE} / 32); return 0;}"
+        TOOLCHAIN_C_FLAGS TOOLCHAIN_CXX_FLAGS
+        SIMD_RISCV_RVV_C_FLAGS SIMD_RISCV_RVV_CXX_FLAGS
+        "-march=rv64gcv_zvl${GMX_SIMD_RISCV_RVV_LENGTH_VALUE}b -mrvv-vector-bits=zvl"
+        "-march=rv64gcv -mrvv-vector-bits=zvl")
+
+    if(${SIMD_RISCV_RVV_C_FLAGS_RESULT})
+        set(${C_FLAGS_VARIABLE} "${TOOLCHAIN_C_FLAGS} ${SIMD_RISCV_RVV_C_FLAGS}" CACHE INTERNAL "C flags required for RISC-V RVV instructions")
+    endif()
+    if(${SIMD_RISCV_RVV_CXX_FLAGS_RESULT})
+        set(${CXX_FLAGS_VARIABLE} "${TOOLCHAIN_CXX_FLAGS} ${SIMD_RISCV_RVV_CXX_FLAGS}" CACHE INTERNAL "C++ flags required for RISC-V RVV instructions")
+    endif()
+    set(${C_FLAGS_RESULT} ${SIMD_RISCV_RVV_C_FLAGS_RESULT} CACHE INTERNAL "Result of test for RISC-V RVV C flags" FORCE)
+    set(${CXX_FLAGS_RESULT} ${SIMD_RISCV_RVV_CXX_FLAGS_RESULT} CACHE INTERNAL "Result of test for RISC-V RVV C++ flags" FORCE)
+endfunction()
+
