+/*
+ * RISC-V RVV 1.0 support for GROMACS. Translated from impl_arm_sve_general.h.
+ *
+ * NOTE: the SVE backend defined a family of SVE_*_MASK macros
+ * (svptrue_bN, svwhilelt_bN, svptrue_pat_bN) because SVE predicates every op.
+ * RVV does not need them: element counts are carried by an explicit vl
+ * argument on every intrinsic, and conditional predication uses masked-op
+ * variants (_m / _mu suffixes) with vbool*_t masks (kickoff sec.3a). So none of
+ * those SVE mask macros translate -- only simdPrefetch carries over.
+ */
+
+#ifndef GMX_SIMD_IMPL_RISCV_RVV_GENERAL_H
+#define GMX_SIMD_IMPL_RISCV_RVV_GENERAL_H
+
+namespace gmx
+{
+
+static inline void simdPrefetch(void* m)
+{
+#ifdef __GNUC__
+    __builtin_prefetch(m);
+#endif
+}
+
+} // namespace gmx
+
+#endif // GMX_SIMD_IMPL_RISCV_RVV_GENERAL_H
