+/*
+ * RISC-V RVV 1.0 support for GROMACS. Translated from impl_arm_sve_simd_float.h.
+ *
+ * Target: SpaceMiT X60, VLEN=256 (zvl256b) => 8 float32 lanes at LMUL=1.
+ * Milestone 1 scope: float32 load/store/arith/logic/compare/select/convert.
+ * rsqrt/rcp accuracy refinement, gather/scatter (util), double, and simd4 are
+ * out of M1 (kickoff sec.5); rsqrt/rcp here give the 7-bit seed only.
+ *
+ * SVE->RVV translation notes (kickoff sec.3):
+ *  (a) SVE predicates every op with an all-true svptrue_b32(); RVV carries the
+ *      element count in an explicit vl and uses plain (unmasked) ops for the
+ *      all-active case. We drop the always-true predicate and pass vl=GMX_...
+ *      _FLOAT_WIDTH. Only genuinely conditional SVE predication maps to RVV
+ *      masked variants.
+ *  (b) Comparisons produce an ephemeral vbool32_t (SEW/LMUL ratio 32 => 1 mask
+ *      bit per f32 lane, 8 active bits at VLEN=256), but SimdFBool/SimdFIBool
+ *      store the mask as a sized vuint32m1_t (see the mask-storage note below),
+ *      since GCC 14.3 cannot make vbool32_t a class member. Off-by-one on mask
+ *      width is a silent-corruptness bug; the simd.cpp mask tests are the guardrail.
+ *
+ * Fixed-length types via riscv_rvv_vector_bits(256) require -mrvv-vector-bits=zvl
+ * (confirmed on hardware: sizeof==32, kickoff sec.6 probe 1).
+ */
+
+#ifndef GMX_SIMD_IMPL_RISCV_RVV_SIMD_FLOAT_H
+#define GMX_SIMD_IMPL_RISCV_RVV_SIMD_FLOAT_H
+
+#include "config.h"
+
+#include <riscv_vector.h>
+
+#include <cassert>
+#include <cstddef>
+#include <cstdint>
+
+#include "gromacs/math/utilities.h"
+
+namespace gmx
+{
+
+// Fixed vector length at VLEN=256. GMX_SIMD_FLOAT_WIDTH == 8. Using a named
+// constant (rather than a runtime vsetvl) keeps every intrinsic's vl argument a
+// compile-time constant, which the fixed-vector-bits ABI requires.
+static const size_t gmxRvvVlF = GMX_SIMD_FLOAT_WIDTH;
+
+class SimdFloat
+{
+private:
+    typedef vfloat32m1_t simdInternalType_ __attribute__((riscv_rvv_vector_bits(GMX_SIMD_RISCV_RVV_LENGTH_VALUE)));
+
+public:
+    SimdFloat() {}
+
+    SimdFloat(const float f) { this->simdInternal_ = __riscv_vfmv_v_f_f32m1(f, gmxRvvVlF); }
+
+    SimdFloat(vfloat32m1_t simd) : simdInternal_(simd) {}
+
+    simdInternalType_ simdInternal_;
+};
+
+class SimdFInt32
+{
+private:
+    typedef vint32m1_t simdInternalType_ __attribute__((riscv_rvv_vector_bits(GMX_SIMD_RISCV_RVV_LENGTH_VALUE)));
+
+public:
+    SimdFInt32() {}
+
+    SimdFInt32(const int32_t i) { this->simdInternal_ = __riscv_vmv_v_x_i32m1(i, gmxRvvVlF); }
+
+    SimdFInt32(vint32m1_t simd) : simdInternal_(simd) {}
+
+    simdInternalType_ simdInternal_;
+};
+
+// Mask storage strategy (Oracle option A): vbool32_t is a *sizeless* type and
+// GCC 14.3 does NOT apply riscv_rvv_vector_bits() to it, so it cannot be a class
+// member. We instead store a SIZED lane mask as vuint32m1_t with each lane set to
+// 0x0 (false) or 0xFFFFFFFF (true). vbool32_t masks are treated as ephemeral,
+// living only at intrinsic call boundaries. Helpers below convert between the
+// two representations. NOTE: never vreinterpret between vbool32_t and vuint32m1_t
+// (a vbool32_t is a packed predicate bitmap, NOT a lane vector).
+typedef vuint32m1_t simdBoolStore_ __attribute__((riscv_rvv_vector_bits(GMX_SIMD_RISCV_RVV_LENGTH_VALUE)));
+
+// vbool32_t (ephemeral) -> sized lane mask (0x0 / 0xFFFFFFFF per lane).
+static inline simdBoolStore_ gmx_simdcall rvvMaskToStore(vbool32_t m)
+{
+    vuint32m1_t zero = __riscv_vmv_v_x_u32m1(0u, gmxRvvVlF);
+    return __riscv_vmerge_vxm_u32m1(zero, 0xFFFFFFFFu, m, gmxRvvVlF);
+}
+
+// sized lane mask -> vbool32_t (ephemeral): true where lane != 0.
+static inline vbool32_t gmx_simdcall rvvStoreToMask(simdBoolStore_ s)
+{
+    return __riscv_vmsne_vx_u32m1_b32(s, 0u, gmxRvvVlF);
+}
+
+class SimdFBool
+{
+public:
+    SimdFBool() {}
+
+    SimdFBool(const bool b)
+    {
+        this->simdInternal_ = __riscv_vmv_v_x_u32m1(b ? 0xFFFFFFFFu : 0u, gmxRvvVlF);
+    }
+
+    SimdFBool(vbool32_t simd) : simdInternal_(rvvMaskToStore(simd)) {}
+
+    SimdFBool(simdBoolStore_ store) : simdInternal_(store) {}
+
+    simdBoolStore_ simdInternal_;
+};
+
+class SimdFIBool
+{
+public:
+    SimdFIBool() {}
+
+    SimdFIBool(const bool b)
+    {
