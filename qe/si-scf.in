&control
    calculation = 'scf'
    prefix      = 'si'
    pseudo_dir  = '.'
    outdir      = './out'
    verbosity   = 'high'
    disk_io     = 'none'
/
&system
    ibrav       = 2
    celldm(1)   = 10.2
    nat         = 2
    ntyp        = 1
    ecutwfc     = 40.0
    nbnd        = 16
/
&electrons
    diagonalization = 'david'
    mixing_beta     = 0.7
    conv_thr        = 1.0d-8
/
ATOMIC_SPECIES
 Si 28.0855 Si.pz-vbc.UPF
ATOMIC_POSITIONS alat
 Si 0.00 0.00 0.00
 Si 0.25 0.25 0.25
K_POINTS gamma
