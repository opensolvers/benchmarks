&control
    calculation = 'scf'
    prefix      = 'si64'
    pseudo_dir  = '.'
    outdir      = './out'
    verbosity   = 'high'
    disk_io     = 'none'
/
&system
    ibrav       = 1
    celldm(1)   = 20.5200
    nat         = 64
    ntyp        = 1
    ecutwfc     = 22.0
    nbnd        = 136
/
&electrons
    electron_maxstep  = 4
    scf_must_converge = .false.
    diagonalization   = 'david'
    mixing_beta       = 0.7
    conv_thr          = 1.0d-6
/
